# ---------------------------------------------------------------------------
# These values live in GitHub Actions secrets, NOT in this file and NOT in git.
# This file only documents which variables the worker expects.
# (Settings -> Secrets and variables -> Actions -> New repository secret)
# ---------------------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID of your PRIVATE test channel (often a negative number, e.g. -1001234567890)
TELEGRAM_CHAT_ID=

# OpenAI API key
OPENAI_API_KEY=

# Supabase project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=

# Supabase service_role key (server-side only — keep secret)
SUPABASE_SERVICE_KEY=

# ---- Optional tuning (have sensible defaults) ----
# Only post items published within this many hours (avoids replaying old items)
MAX_AGE_HOURS=2
# Max AI classification calls per run (cost guard)
MAX_AI_CALLS=10
# Set to true to send ONE canned test alert to Telegram, then exit (bypasses
# feeds/keyword/AI). Use it once to confirm Telegram works, then clear it.
FORCE_TEST_ALERT=

# ---- AI provider ----
# Default is OpenAI. To use DeepSeek (OpenAI-compatible) instead:
#   OPENAI_API_KEY  = your DeepSeek API key
#   OPENAI_BASE_URL = https://api.deepseek.com
#   OPENAI_MODEL    = deepseek-v4-pro (or deepseek-v4-flash; deepseek-chat is a legacy alias)
OPENAI_MODEL=gpt-4o-mini
# Leave blank for OpenAI; set to https://api.deepseek.com for DeepSeek
OPENAI_BASE_URL=
